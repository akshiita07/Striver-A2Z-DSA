class Solution {
public:
    int maxIceCream(vector<int>& costs, int coins) {
        int n=costs.size();
        int ans=0;
        // sort prices of ice creams
        sort(costs.begin(),costs.end());
        // maximise no of ice creams bought:
        for(int i=0;i<n;i++){
            if(costs[i]<=coins){
                //buy:
                ans++;
                coins-=costs[i];
            }
        }
        return ans;
    }
};
